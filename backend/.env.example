# Base de données
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME"

# JWT — générer avec : node -e "require('crypto').randomBytes(56).toString('hex') |> console.log"
JWT_SECRET="CHANGE_ME_56_CHARS_MIN"

# Environnement
NODE_ENV="development"
PORT=3003

# CORS
CORS_ORIGIN="https://monsite.fr"
CORS_ORIGIN_DEV="http://localhost:5173"

# Email — Resend (resend.com)
RESEND_API_KEY="re_XXXXXXXXXXXX"
EMAIL_FROM="noreply@mondomaine.fr"
EMAIL_CONTACT="contact@mondomaine.fr"

# Cloudflare R2 (stockage images)
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="XXXXXXXXXXXX"
S3_SECRET_ACCESS_KEY="XXXXXXXXXXXX"
S3_BUCKET="mon-bucket"
S3_PUBLIC_URL="https://pub-XXXX.r2.dev"

# URL frontend (pour les liens dans les emails)
FRONTEND_URL="https://monsite.fr"

# Instagram Graph API (optionnel — pour afficher les posts dans la galerie)
# Tutoriel : https://developers.facebook.com/docs/instagram-basic-display-api
# 1. Créer une app Facebook → ajouter Instagram Basic Display
# 2. Générer un token court → l'échanger en token long-lived (60 jours)
# 3. Renouveler avant expiration via GET /api/instagram/refresh (admin)
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_USER_ID=""
